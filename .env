# ─── Reconnaissance faciale — MTCNN + FaceNet-128 ────────────
# Seuil de distance L2 pour la reconnaissance (0.0–2.0)
# Plus bas = plus strict. Recommandé : 0.80–1.00
FACE_RECOGNITION_TOLERANCE=0.90
# hog → remplacé par MTCNN, cette variable contrôle le fallback
FACE_DETECTION_MODEL=mtcnn
MAX_PHOTO_SIZE_MB=5
PHOTO_STORAGE_PATH=./data/photos

# ─── Caméra ──────────────────────────────────────────────────
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=15
CAPTURE_INTERVAL_SECONDS=5

# ─── Politique de rétention CNDP ─────────────────────────────
DATA_RETENTION_DAYS=365
CONSENT_REQUIRED=True
ANONYMIZE_AFTER_DAYS=730

# ─── Sécurité authentification ───────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

