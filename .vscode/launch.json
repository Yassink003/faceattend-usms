{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🚀 Flask — FaceAttend",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "args": ["run", "--host=0.0.0.0", "--port=5000", "--reload"],
      "env": {
        "FLASK_APP": "run.py",
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1"
      },
      "jinja": true,
      "justMyCode": true
    },
    {
      "name": "🌱 Seed Database",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "args": ["seed-db"],
      "env": {
        "FLASK_APP": "run.py",
        "FLASK_ENV": "development"
      },
      "justMyCode": true
    },
    {
      "name": "🗄️ Init & Migrate DB",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "args": ["db", "upgrade"],
      "env": {
        "FLASK_APP": "run.py",
        "FLASK_ENV": "development"
      },
      "justMyCode": true
    }
  ]
}
